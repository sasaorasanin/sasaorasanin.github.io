---
import Layout from '../layouts/Layout.astro';
import CvPage from '../components/CvPage.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const versions = await getCollection('versions');
	return versions
		.filter((entry) => entry.data.slug !== 'full')
		.map((entry) => ({
			params: { version: entry.data.slug }
		}));
}

const versionSlug = Astro.params.version ?? 'full';
const siteEntries = await getCollection('site');
const site =
	siteEntries.find((entry) => entry.id === versionSlug || entry.data.displayOn?.includes(versionSlug)) ??
	siteEntries.find((entry) => entry.id === 'full') ??
	siteEntries[0];
const aboutMeEntries = await getCollection('aboutMe');
const aboutMe =
	aboutMeEntries.find((entry) => entry.id === versionSlug || entry.data.displayOn?.includes(versionSlug)) ??
	aboutMeEntries.find((entry) => entry.id === 'full') ??
	aboutMeEntries[0];
---

<Layout title={`${site.data.title} | ${versionSlug} CV`} description={aboutMe.data.headline}>
	<CvPage versionSlug={versionSlug} />
</Layout>
